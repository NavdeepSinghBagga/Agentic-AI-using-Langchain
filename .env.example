# AI Agent Configuration - Environment Variables
# Copy this file to .env and fill in your actual API keys

# ============================================================================
# OpenWeatherMap API
# ============================================================================
# Get your free API key at: https://openweathermap.org/api
# Free tier: 1,000 calls/day, 60 calls/minute
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ============================================================================
# NewsAPI
# ============================================================================
# Get your free API key at: https://newsapi.org/
# Free tier: 100 requests/day
NEWS_API_KEY=your_news_api_key_here

# ============================================================================
# Observability Configuration (Arize Phoenix)
# ============================================================================
# Enable local tracing via Docker. Default Phoenix port is 6006.
# Leave blank to disable observability.
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_PROJECT_NAME=agent_presentation

# ============================================================================
# Ollama Configuration
# ============================================================================
# Default model to use (llama2, mistral, codellama, etc.)
OLLAMA_MODEL=llama3.1:8b

# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# Agent Configuration
# ============================================================================
# Maximum iterations for agent loops (prevents infinite loops)
MAX_AGENT_ITERATIONS=5

# Timeout for tool execution (seconds)
TOOL_TIMEOUT=10

# Maximum tokens for conversation memory
MAX_MEMORY_TOKENS=2000

# Agent output display mode:
#   "stream"  = Real-time step-by-step (best for live demos)
#   "summary" = Post-execution formatted flow
AGENT_OUTPUT_MODE=stream

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable verbose output for debugging
VERBOSE=true